# ===== docker/.env — copy to .env and fill in =====
# Domain you own and have pointed (A record) at this VPS.
APP_DOMAIN=callescort24.org

# Email for Let's Encrypt expiry notices.
ACME_EMAIL=support@callescort24.org

# Generated by bootstrap.sh — pasted in from /opt/supabase/docker/.env
ANON_KEY=
SERVICE_ROLE_KEY=

# Supabase Studio basic-auth (generated by bootstrap.sh)
STUDIO_BASIC_AUTH_USER=admin
STUDIO_BASIC_AUTH_HASH=
